{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lexis",
  "version": "0.3.0",
  "identifier": "com.scott.lexis",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "lexis",
        "width": 980,
        "height": 720,
        "minWidth": 720,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://api.dictionaryapi.dev https://api.datamuse.com https://en.wiktionary.org https://api.github.com"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFMTQxMzhCRERCOURFRTYKUldUbTNybmRpeE1VM2l0RnhSektSM1J1c3BROTRkcDB6bjM1WlJHeitjaFd1VVRyU2M3M3YrcWsK",
      "endpoints": [
        "https://github.com/scotej/lexis/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
