{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lexis",
  "version": "0.1.0",
  "identifier": "com.scott.lexis",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "lexis",
        "width": 980,
        "height": 720,
        "minWidth": 720,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
